# ─── Supabase (wajib) ───────────────────────────────────────────────
# Project Settings → API. URL + anon key aman di client (RLS jadi batas).
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service-role key — SERVER ONLY, jangan kasih prefix NEXT_PUBLIC_.
# Dipakai admin client (cron snapshot, credit metering, delete-account).
# Tanpa ini, fitur tsb degrade graceful (fallback ke user client).
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── AI (wajib buat fitur AI: receipt scan, parse, riset, playbook) ──
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ─── Cron (wajib di Vercel Pro buat portfolio-snapshots) ────────────
# Bearer token yang divalidasi route cron. Generate: openssl rand -hex 32
# Paste OUTPUT hex-nya, BUKAN perintahnya.
CRON_SECRET=your-random-hex-secret

# ─── Email transaksional (opsional — Resend) ───────────────────────
RESEND_API_KEY=re_xxxxxxxx

# ─── Observability (opsional — Sentry) ─────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ─── Billing SaaS master switch (default: BEKU / OFF) ───────────────
# Sakelar SEMUA permukaan billing: pricing landing, halaman upgrade, label
# paket, badge kredit AI, metering kredit, route checkout/webhook (404),
# dan email trial/renewal. App dipakai pribadi dulu — set '1' HANYA kalau
# mau jualan lagi. Lihat src/lib/billing-flag.ts.
NEXT_PUBLIC_BILLING_ENABLED=0

# ─── Pembayaran / Xendit (OFF sampai NIB keluar) ────────────────────
# Gerbang utama. Selama BUKAN 'true', checkout + webhook mati total (503) —
# tidak ada perubahan perilaku app. Nyalakan HANYA setelah 3 hal di bawah siap.
BILLING_ENABLED=false
# Secret key Xendit (dashboard Xendit → Settings → API Keys). SERVER ONLY.
XENDIT_SECRET_KEY=
# Callback verification token (dashboard Xendit → Webhooks). Divalidasi tiap webhook.
XENDIT_CALLBACK_TOKEN=

# ─── Demo mode (opsional) ───────────────────────────────────────────
# 'true' = bypass auth + mock client buat screenshot. JANGAN 'true' di prod.
NEXT_PUBLIC_DEMO_MODE=false
